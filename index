    .btn-rsvp:active { transform: translateY(0); box-shadow: 0 0 20px rgba(212,175,55,0.3); }
    .rsvp-footnote {
      margin-top: var(--space-8);
      font-size: var(--text-sm);
      color: var(--text-faint);
      letter-spacing: 0.05em;
    }

    /* ─── FOOTER ────────────────────────────────── */
    .site-footer {
      padding-block: clamp(var(--space-12), 6vw, var(--space-20));
      border-top: 1px solid var(--divider);
      text-align: center;
      background: var(--black-2);
      position: relative;
      z-index: 3;
    }
    .footer-inner { display: flex; flex-direction: column; align-items: center; gap: var(--space-4); }
    .footer-monogram {
      font-family: var(--font-display);
      font-size: var(--text-xl);
      color: var(--gold);
      opacity: 0.55;
      letter-spacing: 0.2em;
    }
    .footer-text {
      font-family: var(--font-body);
      font-size: var(--text-sm);
      color: var(--text-faint);
      letter-spacing: 0.1em;
    }
    .footer-quote {
      font-family: var(--font-arabic);
      font-size: clamp(1rem, 0.9rem + 0.5vw, 1.4rem);
      color: var(--text-muted);
      opacity: 0.6;
      line-height: 1.8;
    }

    /* ─── COUNTDOWN ─────────────────────────────── */
    .countdown-row {
      display: flex;
      justify-content: center;
      gap: clamp(var(--space-6), 4vw, var(--space-10));
      flex-wrap: wrap;
    }
    .countdown-unit {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-2);
    }
    .countdown-num {
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      font-weight: 400;
      color: var(--gold);
      line-height: 1;
      min-width: 3ch;
      text-align: center;
    }
    .countdown-label {
      font-family: var(--font-body);
      font-size: var(--text-xs);
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--text-faint);
    }
    .countdown-sep {
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      color: var(--gold);
      opacity: 0.3;
      align-self: flex-start;
      padding-top: 4px;
    }

    /* ─── MODAL ─────────────────────────────────── */
    .modal-overlay {
      position: fixed; inset: 0;
      background: rgba(0,0,0,0.8);
      z-index: 500;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--space-4);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }
    .modal-overlay.open { opacity: 1; pointer-events: auto; }
    .modal-box {
      background: var(--black-3);
      border: 1px solid rgba(212,175,55,0.2);
      border-radius: var(--radius-xl);
      padding: clamp(var(--space-8), 5vw, var(--space-12));
      max-width: 500px;
      width: 100%;
      position: relative;
      transform: translateY(20px);
      transition: transform 0.3s var(--ease-out);
    }
    .modal-overlay.open .modal-box { transform: translateY(0); }
    .modal-close {
      position: absolute;
      top: var(--space-4); right: var(--space-4);
      width: 32px; height: 32px;
      display: flex; align-items: center; justify-content: center;
      color: var(--text-muted);
      border-radius: 50%;
    }
    .modal-close:hover { color: var(--text); background: rgba(255,255,255,0.06); }
    .modal-title {
      font-family: var(--font-display);
      font-size: var(--text-xl);
      color: var(--text);
      margin-bottom: var(--space-6);
    }
    .modal-fields { display: flex; flex-direction: column; gap: var(--space-4); }
    .modal-label {
      font-family: var(--font-body);
      font-size: var(--text-xs);
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--text-faint);
      display: block;
      margin-bottom: var(--space-2);
    }
    .modal-input, .modal-select {
      width: 100%;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(212,175,55,0.15);
      border-radius: var(--radius-md);
      padding: var(--space-3) var(--space-4);
      color: var(--text);
      font-size: var(--text-sm);
      outline: none;
    }
    .modal-input:focus, .modal-select:focus {
      border-color: rgba(212,175,55,0.45);
      box-shadow: 0 0 0 3px rgba(212,175,55,0.1);
    }
    .modal-select { appearance: none; -webkit-appearance: none; }
    .btn-submit {
      width: 100%;
      padding: var(--space-4);
      background: var(--gold);
      color: var(--black);
      border-radius: 2px;
      font-family: var(--font-body);
      font-size: var(--text-sm);
      letter-spacing: 0.2em;
      text-transform: uppercase;
      font-weight: 500;
      margin-top: var(--space-2);
      transition: background 0.2s, box-shadow 0.2s, transform 0.2s;
    }
    .btn-submit:hover {
      background: var(--gold-light);
      box-shadow: 0 0 30px rgba(212,175,55,0.4);
      transform: translateY(-1px);
    }
    .modal-success {
      text-align: center;
      padding: var(--space-8) 0;
      display: none;
    }
    .modal-success-icon { font-size: 2.5rem; color: var(--gold); margin-bottom: var(--space-4); }
    .modal-success p { font-family: var(--font-body); color: var(--text-muted); font-size: var(--text-base); }
    .modal-success .arabic-confirm {
      font-family: var(--font-arabic);
      font-size: 1.4rem;
      color: var(--gold);
      opacity: 0.8;
      margin-top: var(--space-3);
    }
  </style>
</head>
