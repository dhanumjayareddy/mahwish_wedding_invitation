    }
    .rsvp-inner { position: relative; z-index: 3; display: flex; flex-direction: column; align-items: center; }
    .rsvp-arabic {
      font-family: var(--font-arabic);
      font-size: clamp(1.3rem, 1rem + 1.5vw, 2.2rem);
      color: var(--gold);
      opacity: 0.75;
      margin-bottom: var(--space-4);
      line-height: 1.8;
    }
    .rsvp-text {
      font-family: var(--font-body);
      font-size: var(--text-base);
      font-weight: 300;
      color: var(--text-muted);
      line-height: 1.9;
      max-width: 48ch;
      text-align: center;
      margin-bottom: clamp(var(--space-8), 5vw, var(--space-10));
    }
    .btn-rsvp {
      display: inline-flex;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-4) clamp(var(--space-8), 5vw, var(--space-12));
      font-family: var(--font-body);
      font-size: var(--text-sm);
      font-weight: 400;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--black);
      background: var(--gold);
      border: 1px solid var(--gold);
      border-radius: 2px;
      position: relative;
      overflow: hidden;
    }
    .btn-rsvp::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(circle at 50% 50%, rgba(255,255,255,0.2) 0%, transparent 70%);
      opacity: 0;
      transition: opacity 0.3s;
    }
    .btn-rsvp:hover {
      background: var(--gold-light);
      border-color: var(--gold-light);
      box-shadow: 0 0 40px rgba(212,175,55,0.55), 0 8px 32px rgba(212,175,55,0.3);
      transform: translateY(-2px);
