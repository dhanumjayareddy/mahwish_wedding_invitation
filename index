  }

  intro.addEventListener('click', openInvitation);
  intro.addEventListener('keydown', e=>{ if(e.key==='Enter'||e.key===' ') openInvitation(); });
})();

/* ─── LANTERNS ──────────────────────────────────────── */
function startLanterns(){
  const canvas = document.getElementById('lantern-canvas');
  const ctx = canvas.getContext('2d');
  let W, H;

  function resize(){ W = canvas.width = window.innerWidth; H = canvas.height = window.innerHeight; }
  resize();
  window.addEventListener('resize', resize);

  const lanterns = Array.from({length:14}, ()=>({
    x: Math.random()*window.innerWidth,
    y: window.innerHeight + Math.random()*300,
    size: Math.random()*14+10,
    speedY: Math.random()*0.4+0.2,
    drift: (Math.random()-0.5)*0.3,
    glow: Math.random()*0.5+0.4,
    phase: Math.random()*Math.PI*2,
    hue: Math.random()*30-15
  }));

  function drawLantern(x,y,s,glow){
    ctx.save();
    ctx.translate(x,y);
    // glow
    const g = ctx.createRadialGradient(0,0,0,0,0,s*2.5);
    g.addColorStop(0,`rgba(${212+lanterns[0].hue},${175},55,${glow*0.35})`);
    g.addColorStop(1,'rgba(212,140,0,0)');
    ctx.fillStyle=g;
    ctx.beginPath(); ctx.arc(0,0,s*2.5,0,Math.PI*2); ctx.fill();
    // body
    ctx.beginPath();
    ctx.moveTo(-s*0.5,-s*0.8);
    ctx.bezierCurveTo(-s*0.7,-s*0.2,-s*0.7,s*0.2,-s*0.45,s*0.8);
    ctx.lineTo(s*0.45,s*0.8);
    ctx.bezierCurveTo(s*0.7,s*0.2,s*0.7,-s*0.2,s*0.5,-s*0.8);
    ctx.closePath();
    const lg = ctx.createLinearGradient(-s,0,s,0);
    lg.addColorStop(0,'rgba(180,100,0,0.7)');
    lg.addColorStop(0.4,`rgba(255,180,30,${glow})`);
    lg.addColorStop(1,'rgba(180,80,0,0.5)');
    ctx.fillStyle=lg;
    ctx.fill();
    // top/bottom lines
    ctx.strokeStyle='rgba(212,175,55,0.5)'; ctx.lineWidth=1;
    ctx.beginPath(); ctx.moveTo(-s*0.5,-s*0.8); ctx.lineTo(s*0.5,-s*0.8); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(-s*0.45,s*0.8); ctx.lineTo(s*0.45,s*0.8); ctx.stroke();
    // string
    ctx.strokeStyle='rgba(212,175,55,0.3)'; ctx.lineWidth=0.5;
    ctx.beginPath(); ctx.moveTo(0,-s*0.8); ctx.lineTo(0,-s*1.6); ctx.stroke();
    ctx.restore();
  }

  function animate(){
    ctx.clearRect(0,0,W,H);
    const t = Date.now()/1000;
    lanterns.forEach(l=>{
      l.y -= l.speedY;
      l.x += l.drift + Math.sin(t*0.5+l.phase)*0.3;
      if(l.y < -100){
        l.y = H+50;
        l.x = Math.random()*W;
      }
      drawLantern(l.x,l.y,l.size,l.glow);
    });
    requestAnimationFrame(animate);
  }
  animate();
}

/* ─── COUNTDOWN ─────────────────────────────────────── */
function startCountdown(){
  const target = new Date('2026-08-23T08:00:00+05:30').getTime();
  function update(){
    const diff = target - Date.now();
    if(diff<=0){
      ['cd-days','cd-hours','cd-mins','cd-secs'].forEach(id=>{
        document.getElementById(id).textContent='00';
      });
      return;
    }
    const d = Math.floor(diff/86400000);
    const h = Math.floor((diff%86400000)/3600000);
    const m = Math.floor((diff%3600000)/60000);
    const s = Math.floor((diff%60000)/1000);
    document.getElementById('cd-days').textContent  = String(d).padStart(2,'0');
    document.getElementById('cd-hours').textContent = String(h).padStart(2,'0');
    document.getElementById('cd-mins').textContent  = String(m).padStart(2,'0');
    document.getElementById('cd-secs').textContent  = String(s).padStart(2,'0');
  }
  update();
  setInterval(update,1000);
}

/* ─── SCROLL REVEAL ─────────────────────────────────── */
function initScrollReveal(){
  const els = document.querySelectorAll('.reveal-fade, .reveal-scale');
  const observer = new IntersectionObserver(entries=>{
    entries.forEach((e,i)=>{
      if(e.isIntersecting){
        setTimeout(()=>e.target.classList.add('in-view'), i*60);
        observer.unobserve(e.target);
      }
    });
  },{threshold:0.12});
  els.forEach(el=>observer.observe(el));
  // Fire visible ones immediately
  setTimeout(()=>{
    document.querySelectorAll('#hero .reveal-fade, #hero .reveal-scale').forEach(el=>{
      el.classList.add('in-view');
    });
  },300);
}

/* ─── MUSIC TOGGLE ──────────────────────────────────── */
(function(){
  const btn    = document.getElementById('music-toggle');
  const iconOn = document.getElementById('icon-music-on');
  const iconOff= document.getElementById('icon-music-off');
  let playing  = false;
  let ctx, osc, gain;

  function startAmbient(){
    ctx  = new (window.AudioContext||window.webkitAudioContext)();
    gain = ctx.createGain();
    gain.gain.value = 0.03;
    gain.connect(ctx.destination);

    function addTone(freq,vol){
      const o = ctx.createOscillator();
      const g = ctx.createGain();
      o.frequency.value = freq;
      o.type = 'sine';
      g.gain.value = vol;
      o.connect(g); g.connect(gain);
      o.start();
      return o;
    }
    addTone(220, 0.5);
    addTone(330, 0.3);
    addTone(440, 0.15);
    addTone(110, 0.2);
  }

  btn.addEventListener('click',()=>{
    playing = !playing;
    iconOn.style.display  = playing ? 'none'  : '';
    iconOff.style.display = playing ? ''      : 'none';
    btn.setAttribute('aria-label', playing ? 'Mute ambient music' : 'Play ambient music');
    if(playing){
      if(!ctx) startAmbient();
      else ctx.resume();
    } else {
      if(ctx) ctx.suspend();
    }
  });
})();

/* ─── RSVP MODAL ─────────────────────────────────────── */
(function(){
  const overlay = document.getElementById('modal-overlay');
  const btn     = document.getElementById('rsvp-btn');
  const close   = document.getElementById('modal-close');
  const form    = document.getElementById('rsvp-form');
  const success = document.getElementById('rsvp-success');

  function openModal(){
    overlay.classList.add('open');
    overlay.removeAttribute('aria-hidden');
    document.body.style.overflow='hidden';
    close.focus();
  }
  function closeModal(){
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden','true');
    document.body.style.overflow='';
    btn.focus();
  }

  btn.addEventListener('click', openModal);
  close.addEventListener('click', closeModal);
  overlay.addEventListener('click', e=>{ if(e.target===overlay) closeModal(); });
  document.addEventListener('keydown', e=>{ if(e.key==='Escape') closeModal(); });

  form.addEventListener('submit', e=>{
    e.preventDefault();
    const name = document.getElementById('rsvp-name').value.trim();
    if(!name){ document.getElementById('rsvp-name').focus(); return; }
    form.style.display='none';
    success.style.display='flex';
    success.style.flexDirection='column';
    success.style.alignItems='center';
  });
})();

