<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mohammad Akhlak Alam & Mahwish Lais — 23 August 2026</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400;1,500&family=Inter:wght@300;400;500&family=Amiri:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet" />
  <style>
    /* =============================================
       ART DIRECTION: Islamic Nikah — Deep emerald 
       dusk, gold filigree, arabesque warmth.
       Palette: #0A0D0A (deep), #D4AF37 (gold), 
                #1a3a1a (emerald shadow), #8B1A2A (maroon accent)
       Fonts: Playfair Display (display) + Inter (body) + Amiri (Arabic)
    ============================================= */
    :root {
      --gold:        #D4AF37;
      --gold-light:  #e8cc6a;
      --gold-dim:    rgba(212,175,55,0.18);
      --gold-glow:   rgba(212,175,55,0.35);
      --black:       #0A0D0A;
      --black-2:     #0f140f;
      --black-3:     #141a14;
      --emerald-dim: rgba(20,60,20,0.3);
      --maroon:      #8B1A2A;
      --maroon-dim:  rgba(139,26,42,0.2);
      --text:        #e8e2d0;
      --text-muted:  #9a9080;
      --text-faint:  #4a4640;
      --divider:     rgba(212,175,55,0.15);

      --font-display: 'Playfair Display', Georgia, serif;
      --font-body:    'Inter', 'Helvetica Neue', sans-serif;
      --font-arabic:  'Amiri', Georgia, serif;

      --text-xs:   clamp(0.75rem,  0.7rem  + 0.25vw, 0.875rem);
      --text-sm:   clamp(0.875rem, 0.8rem  + 0.35vw, 1rem);
      --text-base: clamp(1rem,     0.95rem + 0.25vw, 1.125rem);
      --text-lg:   clamp(1.125rem, 1rem    + 0.75vw, 1.5rem);
      --text-xl:   clamp(1.5rem,   1.2rem  + 1.25vw, 2.25rem);
      --text-2xl:  clamp(2rem,     1.2rem  + 2.5vw,  3.5rem);
      --text-3xl:  clamp(2.5rem,   1rem    + 4vw,    5rem);
      --text-hero: clamp(2.8rem,   0.5rem  + 6vw,    6.5rem);
      --text-arabic: clamp(1.6rem, 1.2rem  + 1.5vw,  2.8rem);

      --space-1: 0.25rem;  --space-2: 0.5rem;   --space-3: 0.75rem;
      --space-4: 1rem;     --space-5: 1.25rem;  --space-6: 1.5rem;
      --space-8: 2rem;     --space-10: 2.5rem;  --space-12: 3rem;
      --space-16: 4rem;    --space-20: 5rem;    --space-24: 6rem;

      --radius-sm: 0.375rem;
      --radius-md: 0.5rem;
      --radius-lg: 0.75rem;
      --radius-xl: 1rem;
      --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
      --ease-in:  cubic-bezier(0.4, 0, 1, 1);
      --transition-interactive: 180ms cubic-bezier(0.16, 1, 0.3, 1);
      --content-default: 960px;
      --content-wide: 1200px;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html {
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
      text-rendering: optimizeLegibility;
      scroll-behavior: smooth;
      scroll-padding-top: var(--space-8);
    }
    body {
      min-height: 100dvh;
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--text);
      background: var(--black);
      overflow-x: hidden;
    }
    img, picture, svg, canvas { display: block; max-width: 100%; height: auto; }
    input, button, textarea, select { font: inherit; color: inherit; }
    h1,h2,h3,h4,h5,h6 { text-wrap: balance; line-height: 1.15; }
    p, li { text-wrap: pretty; max-width: 72ch; }
    button { cursor: pointer; background: none; border: none; }
    a { color: inherit; text-decoration: none; }
    a, button, [role="button"] {
      transition: color var(--transition-interactive),
                  background var(--transition-interactive),
                  box-shadow var(--transition-interactive),
                  opacity var(--transition-interactive),
                  transform var(--transition-interactive);
    }
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
        scroll-behavior: auto !important;
      }
    }
    :focus-visible { outline: 2px solid var(--gold); outline-offset: 3px; border-radius: var(--radius-sm); }

    .container {
      max-width: var(--content-default);
      margin-inline: auto;
      padding-inline: clamp(var(--space-4), 5vw, var(--space-12));
    }
    .section {
      padding-block: clamp(var(--space-16), 10vw, var(--space-24));
      position: relative;
    }

    /* ─── INTRO SCREEN ─────────────────────────── */
    .intro {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      background: var(--black);
      overflow: hidden;
    }
    #particle-canvas {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }
    .intro-content {
      position: relative;
      z-index: 10;
      text-align: center;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-5);
      pointer-events: none;
    }
    .intro-bismillah {
      font-family: var(--font-arabic);
      font-size: var(--text-arabic);
      color: var(--gold);
      letter-spacing: 0.05em;
      text-shadow: 0 0 40px rgba(212,175,55,0.5), 0 0 80px rgba(212,175,55,0.2);
      animation: monogram-breathe 3s ease-in-out infinite;
      line-height: 1.6;
    }
    .intro-crescent {
      color: var(--gold);
      opacity: 0.7;
      animation: monogram-breathe 3s ease-in-out infinite 0.5s;
    }
    @keyframes monogram-breathe {
      0%,100% { opacity:0.8; text-shadow:0 0 40px rgba(212,175,55,0.35),0 0 80px rgba(212,175,55,0.15); }
      50%      { opacity:1;   text-shadow:0 0 60px rgba(212,175,55,0.7),0 0 120px rgba(212,175,55,0.35); }
    }
    .intro-hint {
      font-family: var(--font-body);
      font-size: var(--text-sm);
      font-weight: 300;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--text-muted);
      animation: hint-pulse 2.5s ease-in-out infinite;
    }
    @keyframes hint-pulse { 0%,100%{opacity:.45} 50%{opacity:1} }
    .intro-line {
      width: 1px;
      height: 40px;
      background: linear-gradient(to bottom, var(--gold), transparent);
      animation: line-drop 2s ease-in-out infinite;
    }
    @keyframes line-drop {
      0%   { opacity:0; transform:scaleY(0); transform-origin:top; }
      50%  { opacity:1; transform:scaleY(1); }
      100% { opacity:0; transform:scaleY(0); transform-origin:bottom; }
    }

    /* ─── CURTAINS ──────────────────────────────── */
    .curtain {
      position: absolute;
      top: 0; bottom: 0;
      width: 50%;
      z-index: 5;
      will-change: transform;
      overflow: hidden;
    }
    .curtain--left  { left: 0;  }
    .curtain--right { right: 0; }

    /* SVG silk curtain pattern */
    .curtain-svg { width: 100%; height: 100%; position: absolute; inset: 0; }

    .intro.opening .curtain--left  { animation: curtainOpenLeft  1.8s cubic-bezier(0.76,0,0.24,1) forwards; }
    .intro.opening .curtain--right { animation: curtainOpenRight 1.8s cubic-bezier(0.76,0,0.24,1) forwards; }
    .intro.opening .intro-content  { animation: contentFade 0.5s var(--ease-in) forwards; }
    @keyframes curtainOpenLeft  { to { transform: translateX(-105%); } }
    @keyframes curtainOpenRight { to { transform: translateX(105%);  } }
    @keyframes contentFade      { to { opacity: 0; } }
    .intro.hidden { pointer-events:none; opacity:0; transition: opacity 0.4s var(--ease-in) 1.6s; }

    /* ─── MAIN CONTENT ──────────────────────────── */
    .main-content {
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.9s var(--ease-out);
      position: relative;
    }
    .main-content.visible { opacity:1; pointer-events:auto; }

    .lantern-canvas {
      position: fixed;
      inset: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 1;
      opacity: 0.5;
    }
    .vignette {
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 2;
      background: radial-gradient(ellipse at center, transparent 40%, rgba(0,0,0,0.72) 100%);
    }

    /* ─── MUSIC TOGGLE ──────────────────────────── */
    .music-toggle {
      position: fixed;
      top: var(--space-6);
      right: var(--space-6);
      z-index: 100;
      width: 44px; height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      background: rgba(10,13,10,0.7);
      border: 1px solid var(--divider);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    .music-toggle:hover {
      color: var(--gold);
      border-color: rgba(212,175,55,0.4);
      box-shadow: 0 0 20px rgba(212,175,55,0.2);
    }

    /* ─── REVEAL ANIMATIONS ─────────────────────── */
    .reveal-fade {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.9s var(--ease-out), transform 0.9s var(--ease-out);
    }
    .reveal-fade.in-view { opacity:1; transform:translateY(0); }
    .reveal-scale {
      opacity: 0;
      transform: scale(0.97);
      transition: opacity 1.1s var(--ease-out), transform 1.1s var(--ease-out);
    }
    .reveal-scale.in-view { opacity:1; transform:scale(1); }

    /* ─── SECTION LABELS ────────────────────────── */
    .section-label {
      font-family: var(--font-body);
      font-size: var(--text-xs);
      font-weight: 400;
      letter-spacing: 0.4em;
      text-transform: uppercase;
      color: var(--gold);
      margin-bottom: var(--space-4);
    }
    .section-title {
      font-family: var(--font-display);
      font-size: var(--text-2xl);
      font-weight: 400;
      color: var(--text);
      line-height: 1.2;
      margin-bottom: clamp(var(--space-8), 5vw, var(--space-16));
    }
    .section-title em { font-style: italic; color: var(--gold); }

    /* ─── ARABESQUE ORNAMENT ────────────────────── */
    .arabesque {
      width: 100%;
      max-width: 400px;
      margin-inline: auto;
      opacity: 0.25;
    }
    .arabesque-sm { max-width: 200px; opacity: 0.2; }

    /* ─── HERO ──────────────────────────────────── */
    .hero {
      min-height: 100dvh;
      display: flex;
      align-items: center;
      text-align: center;
      overflow: hidden;
      padding-block: clamp(var(--space-20), 12vw, var(--space-24));
      position: relative;
    }
    .hero-bg-gradient {
      position: absolute; inset: 0;
      background:
        radial-gradient(ellipse 80% 60% at 50% 60%, rgba(212,175,55,0.04) 0%, transparent 70%),
        radial-gradient(ellipse 60% 80% at 50% 0%,  rgba(20,60,20,0.15)  0%, transparent 60%);
      pointer-events: none;
    }
    .hero-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--space-6);
      position: relative;
      z-index: 3;
      width: 100%;
    }
    .hero-bismillah {
      font-family: var(--font-arabic);
      font-size: clamp(1.4rem, 1rem + 1.5vw, 2.2rem);
      color: var(--gold);
      opacity: 0.8;
      letter-spacing: 0.05em;
      line-height: 1.8;
    }
    .hero-label {
      font-family: var(--font-body);
      font-size: var(--text-xs);
      letter-spacing: 0.45em;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .hero-image-wrapper {
      position: relative;
      width: min(520px, 88vw);
      margin-inline: auto;
    }
    .hero-image-glow {
      position: absolute;
      inset: -24px;
      border-radius: var(--radius-xl);
      background: radial-gradient(ellipse at center, rgba(212,175,55,0.14) 0%, transparent 70%);
      filter: blur(32px);
      z-index: 0;
    }
    .hero-image {
      width: 100%;
      aspect-ratio: 3/2;
      object-fit: cover;
      border-radius: var(--radius-lg);
      position: relative;
      z-index: 1;
      border: 1px solid rgba(212,175,55,0.22);
      box-shadow: 0 0 60px rgba(212,175,55,0.1), 0 32px 80px rgba(0,0,0,0.7);
    }
    .hero-image-overlay {
      position: absolute; inset: 0;
      border-radius: var(--radius-lg);
      background: linear-gradient(to bottom, transparent 50%, rgba(10,13,10,0.45) 100%);
      z-index: 2;
      pointer-events: none;
    }
    .hero-names {
      font-family: var(--font-display);
      font-size: var(--text-hero);
      font-weight: 400;
      letter-spacing: -0.01em;
      color: var(--text);
      display: flex;
      align-items: center;
      gap: clamp(var(--space-4), 3vw, var(--space-8));
      line-height: 1;
      flex-wrap: wrap;
      justify-content: center;
    }
    .ampersand {
      font-family: var(--font-display);
      font-style: italic;
      color: var(--gold);
      font-size: 0.68em;
      opacity: 0.9;
    }
    .hero-date {
      font-family: var(--font-body);
      font-size: var(--text-base);
      font-weight: 300;
      letter-spacing: 0.3em;
      text-transform: uppercase;
      color: var(--text-muted);
    }
    .hero-location {
      font-family: var(--font-body);
      font-size: var(--text-sm);
      letter-spacing: 0.2em;
      color: var(--text-faint);
    }
    .hero-divider {
      width: 120px;
      height: 1px;
      background: linear-gradient(to right, transparent, var(--gold), transparent);
      margin-top: var(--space-2);
      opacity: 0.55;
    }
    .hero-star-row {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      color: var(--gold);
      opacity: 0.5;
      font-size: 0.7rem;
    }

    /* ─── STORY ─────────────────────────────────── */
    .story-section {
      background: linear-gradient(to bottom, var(--black), var(--black-2), var(--black));
    }
    .story-inner { position: relative; z-index: 3; }
    .story-columns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(var(--space-8), 5vw, var(--space-16));
      margin-bottom: clamp(var(--space-12), 7vw, var(--space-20));
    }
    @media (max-width: 640px) { .story-columns { grid-template-columns: 1fr; } }
    .story-col p {
      font-family: var(--font-body);
      font-size: var(--text-base);
      font-weight: 300;
      line-height: 1.9;
      color: var(--text-muted);
      max-width: 40ch;
    }
    .story-image-row {
      display: grid;
      grid-template-columns: 1fr 1.2fr 1fr;
      gap: var(--space-4);
      align-items: end;
    }
    @media (max-width: 600px) { .story-image-row { grid-template-columns: 1fr; } }
    .story-img-wrap {
      overflow: hidden;
      border-radius: var(--radius-lg);
      border: 1px solid rgba(212,175,55,0.1);
    }
    .story-img-wrap--mid { transform: translateY(-24px); }
    @media (max-width: 600px) { .story-img-wrap--mid { transform: none; } }
    .story-img {
      width: 100%;
      height: 300px;
      object-fit: cover;
      transition: transform 1s var(--ease-out);
    }
    .story-img-wrap:hover .story-img { transform: scale(1.04); }

    /* ─── EVENTS ────────────────────────────────── */
    .events-section { background: var(--black); }
    .events-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(min(280px, 100%), 1fr));
      gap: var(--space-5);
    }
    .event-card {
      padding: clamp(var(--space-6), 3vw, var(--space-8));
      border-radius: var(--radius-xl);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
      position: relative;
      overflow: hidden;
      transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out), border-color 0.4s;
      background: rgba(255,255,255,0.025);
      border: 1px solid rgba(212,175,55,0.12);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      box-shadow: 0 8px 32px rgba(0,0,0,0.4), inset 0 1px 0 rgba(212,175,55,0.06);
    }
    .event-card:hover {
      transform: translateY(-4px);
      border-color: rgba(212,175,55,0.3);
      box-shadow: 0 16px 48px rgba(0,0,0,0.5), 0 0 40px rgba(212,175,55,0.08), inset 0 1px 0 rgba(212,175,55,0.12);
    }
    .event-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(212,175,55,0.5), transparent);
      opacity: 0;
      transition: opacity 0.4s;
    }
    .event-card:hover::before { opacity: 1; }
    .event-card-icon { color: var(--gold); margin-bottom: var(--space-2); opacity: 0.75; }
    .event-card-label {
      font-family: var(--font-body);
      font-size: var(--text-xs);
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--gold);
      opacity: 0.65;
    }
    .event-card-title {
      font-family: var(--font-display);
      font-size: var(--text-lg);
      font-weight: 500;
      color: var(--text);
    }
    .event-card-detail {
      font-family: var(--font-body);
      font-size: var(--text-sm);
      font-weight: 300;
      color: var(--text-muted);
      line-height: 1.65;
    }
    .event-card-loc {
      font-family: var(--font-body);
      font-size: var(--text-sm);
      color: var(--gold);
      opacity: 0.65;
      margin-top: var(--space-2);
      padding-top: var(--space-3);
      border-top: 1px solid rgba(212,175,55,0.1);
    }

    /* ─── GALLERY ───────────────────────────────── */
    .gallery-section { background: var(--black-2); overflow: hidden; }
    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      grid-template-rows: auto auto;
      gap: var(--space-3);
      padding-inline: clamp(var(--space-4), 5vw, var(--space-12));
    }
    @media (max-width: 640px) {
      .gallery-grid { grid-template-columns: 1fr 1fr; }
      .gallery-item { grid-column: auto !important; grid-row: auto !important; }
    }
    .gallery-item {
      overflow: hidden;
      border-radius: var(--radius-lg);
      position: relative;
      cursor: zoom-in;
      border: 1px solid rgba(212,175,55,0.07);
    }
    .gallery-item:nth-child(1) { grid-column: span 3; }
    .gallery-item:nth-child(2) { grid-column: span 4; grid-row: span 2; }
    .gallery-item:nth-child(3) { grid-column: span 5; }
    .gallery-item:nth-child(4) { grid-column: span 5; }
    .gallery-item:nth-child(5) { grid-column: span 3; }
    .gallery-item img {
      width: 100%; height: 100%;
      object-fit: cover;
      min-height: 200px;
      transition: transform 0.8s var(--ease-out), filter 0.4s;
      filter: brightness(0.82) saturate(0.85);
    }
    .gallery-item:hover img { transform: scale(1.06); filter: brightness(1) saturate(1.05); }
    .gallery-overlay {
      position: absolute; inset: 0;
      background: linear-gradient(135deg, rgba(212,175,55,0.0) 0%, rgba(212,175,55,0.05) 100%);
      opacity: 0;
      transition: opacity 0.4s;
      border-radius: inherit;
    }
    .gallery-item:hover .gallery-overlay { opacity: 1; }

    /* ─── MAP SECTION ───────────────────────────── */
    .map-section { background: var(--black); }
    .map-wrapper {
      position: relative;
      width: 100%;
      border-radius: var(--radius-xl);
      overflow: hidden;
      border: 1px solid rgba(212,175,55,0.18);
      box-shadow: 0 0 60px rgba(212,175,55,0.06), 0 24px 64px rgba(0,0,0,0.6);
    }
    .map-iframe {
      width: 100%;
      height: clamp(320px, 45vw, 520px);
      border: none;
      display: block;
      filter: invert(0.9) hue-rotate(160deg) brightness(0.7) saturate(0.9);
    }
    .map-pin-badge {
      position: absolute;
      bottom: var(--space-5);
      left: 50%;
      transform: translateX(-50%);
      background: rgba(10,13,10,0.85);
      border: 1px solid rgba(212,175,55,0.3);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-radius: var(--radius-xl);
      padding: var(--space-3) var(--space-6);
      display: flex;
      align-items: center;
      gap: var(--space-3);
      font-family: var(--font-body);
      font-size: var(--text-sm);
      color: var(--text);
      white-space: nowrap;
    }
    .map-pin-dot {
      width: 8px; height: 8px;
      background: var(--gold);
      border-radius: 50%;
      box-shadow: 0 0 10px var(--gold);
      flex-shrink: 0;
      animation: ping 2s ease-in-out infinite;
    }
    @keyframes ping {
      0%,100% { transform: scale(1); opacity: 1; }
      50%      { transform: scale(1.4); opacity: 0.6; }
    }
    .map-open-link {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      margin-top: var(--space-5);
      font-family: var(--font-body);
      font-size: var(--text-sm);
      letter-spacing: 0.15em;
      color: var(--gold);
      opacity: 0.75;
      text-transform: uppercase;
      border-bottom: 1px solid rgba(212,175,55,0.25);
      padding-bottom: 2px;
      transition: opacity 0.2s, border-color 0.2s;
    }
    .map-open-link:hover { opacity: 1; border-color: var(--gold); }

    /* ─── RSVP ──────────────────────────────────── */
    .rsvp-section { background: var(--black); text-align: center; overflow: hidden; }
